    "Suggested highlight: %@":{"comment":"The placeholder is an AI-provided label for an area to highlight.","localizations":{"ja":{"stringUnit":{"state":"translated","value":"おすすめのハイライト：%@"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"建议高亮：%@"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"建議醒目標示：%@"}}}},
