    "Waiting for the first screen capture...":{"localizations":{"ja":{"stringUnit":{"state":"translated","value":"最初の画面キャプチャを待っています..."}},"zh-Hans":{"stringUnit":{"state":"translated","value":"正在等待首次屏幕捕捉..."}},"zh-Hant":{"stringUnit":{"state":"translated","value":"正在等待首次螢幕擷取..."}}}},
