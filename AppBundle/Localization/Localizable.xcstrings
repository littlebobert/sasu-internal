    "Translation ready.":{"localizations":{"ja":{"stringUnit":{"state":"translated","value":"翻訳の準備ができました。"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"翻译已就绪。"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"翻譯已就緒。"}}}},
    "Try Sasu on this example":{"localizations":{"ja":{"stringUnit":{"state":"translated","value":"この例でSasuを試す"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"通过此示例试用 Sasu"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"透過此範例試用 Sasu"}}}},
