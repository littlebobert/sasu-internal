    "Translate Selected Text Faster?":{"localizations":{"ja":{"stringUnit":{"state":"translated","value":"選択したテキストをより速く翻訳しますか？"}},"zh-Hans":{"stringUnit":{"state":"translated","value":"更快地翻译所选文本？"}},"zh-Hant":{"stringUnit":{"state":"translated","value":"更快地翻譯所選文字？"}}}},
